---
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';
import InquiryModal from '../components/ui/InquiryModal.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { base } from '../utils/base';


interface Props {
  title: string;
  description?: string;
  ogType?: string;
  id?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { 
  title, 
  description = "MF Chemicals - Premium B2B Scientific Supplies & Labware services since 1985. Based in Penang, Malaysia.", 
  ogType = "website",
  id = "",
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Sitewide Organization structured data
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "MF Chemicals Sdn Bhd",
  "alternateName": "MF Chemicals",
  "url": "https://www.mfchemicals.net",
  "logo": `${new URL(`${base}/images/logo-icon.png`, Astro.site)}`,
  "description": "Wholesale B2B supplier of institutional-grade scientific labware, laboratory equipment, and consumable supplies. Established 1985 in Penang, Malaysia.",
  "foundingDate": "1985",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "No. 27, Lorong Asas Jaya 4, Kawasan Industri Ringan Asas Jaya",
    "addressLocality": "Bukit Minyak, Bukit Mertajam",
    "addressRegion": "Penang",
    "postalCode": "14100",
    "addressCountry": "MY"
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+604-5883440",
      "contactType": "sales",
      "areaServed": "MY",
      "availableLanguage": ["English", "Malay", "Chinese"]
    },
    {
      "@type": "ContactPoint",
      "telephone": "+6016-4270012",
      "contactType": "customer service",
      "areaServed": "MY",
      "contactOption": "https://wa.me/60164270012"
    }
  ],
  "sameAs": []
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${base}/images/logo-icon.png`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="r9icCZEU9vZLgLmcHD_nmaSXk3MA_6ejFXa8y3Yq1sQ" />

    <!-- Fonts loaded via @fontsource/inter CSS imports -->

    <!-- Primary Meta Tags -->
    <title>{title} | MF Chemicals</title>
    <meta name="title" content={`${title} | MF Chemicals`} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Geo-Targeting & Language -->
    <link rel="alternate" hreflang="en-MY" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <meta name="geo.region" content="MY-07" />
    <meta name="geo.placename" content="Bukit Minyak, Penang" />
    <meta name="geo.position" content="5.3299;100.4587" />
    <meta name="ICBM" content="5.3299, 100.4587" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={`${title} | MF Chemicals`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${new URL(`${base}/images/og-social-preview.jpg`, Astro.site)}`} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:locale" content="en_MY" />
    <meta property="og:site_name" content="MF Chemicals" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | MF Chemicals`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${new URL(`${base}/images/og-social-preview.jpg`, Astro.site)}`} />
    
    <!-- Additional SEO tags -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="MF Chemicals Sdn Bhd" />
    <meta name="theme-color" content="#0f172a" />

    <!-- AI Content Declaration -->
    <meta name="ai-content-declaration" content="B2B laboratory supplies catalog — MF Chemicals Sdn Bhd, Penang, Malaysia" />
  </head>
  <body class="overflow-x-hidden">
    <!-- Quick Contact Header -->
    <div class="bg-brand-slate-950 text-brand-slate-300 text-xs py-2 px-4 md:px-8 border-b border-brand-slate-800 transition-colors" role="banner">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2">
        <div class="flex items-center gap-4">
          <span class="flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-amber-400 animate-pulse"></span>
            Established 1985 | Bukit Minyak, Penang
          </span>
        </div>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-1">
          <a href="tel:+6045883440" class="hover:text-white transition-colors duration-200" id="quick-tel-1">Tel: +604-5883440</a>
          <a href="https://wa.me/60164270012" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-200" id="quick-whatsapp-1">WhatsApp: +6016-4270012</a>
          <a href="mailto:info@mfchemicals.net" class="hover:text-white transition-colors duration-200" id="quick-email-1">info@mfchemicals.net</a>
        </div>
      </div>
    </div>

    <!-- Main Navigation -->
    <header class="sticky top-0 z-40 bg-white/95 backdrop-blur-md border-b border-brand-slate-100 shadow-sm transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex justify-between items-center">
        <!-- Logo -->
        <a href={`${base}/`} class="flex items-center gap-3 select-none group" id="nav-logo">
          <img 
            src={`${base}/images/logo-icon.png`} 
            alt="MF Chemicals logo icon" 
            class="h-11 w-auto object-contain transition-opacity group-hover:opacity-90"
            width="44"
            height="44"
          />
          <div class="flex flex-col">
            <span class="text-lg font-bold tracking-tight text-brand-slate-900 group-hover:text-brand-slate-700 transition-colors leading-none">
              MF CHEMICALS
            </span>
            <span class="text-[9px] uppercase tracking-widest text-brand-slate-400 font-semibold mt-1 leading-none">
              Scientific Supplies & Services
            </span>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
          <a href={`${base}/`} class="text-sm font-medium text-brand-slate-600 hover:text-brand-steel-600 transition-colors duration-200" aria-current={Astro.url.pathname === '/' ? 'page' : undefined}>
            Home
          </a>
          <div class="relative group">
            <button class="flex items-center gap-1 text-sm font-medium text-brand-slate-600 hover:text-brand-steel-600 transition-colors duration-200 py-2" aria-expanded="false" aria-haspopup="true">
              Categories
              <svg class="w-4 h-4 text-brand-slate-400 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute right-0 top-full w-72 bg-white border border-brand-slate-200 rounded-lg shadow-premium opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 z-50 p-2" role="menu">
              <div class="grid gap-1">
                <a href={`${base}/catalog/glassware`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">1. Glassware</a>
                <a href={`${base}/catalog/porcelainware`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">2. Porcelainware</a>
                <a href={`${base}/catalog/silicaware`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">3. Silicaware</a>
                <a href={`${base}/catalog/plasticware`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">4. Plasticware</a>
                <a href={`${base}/catalog/sundries`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">5. Laboratory Sundries</a>
                <a href={`${base}/catalog/safety`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">6. Laboratory Safety</a>
                <a href={`${base}/catalog/paper`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">7. Paper Products</a>
                <a href={`${base}/catalog/liquid`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">8. Liquid Handling</a>
                <a href={`${base}/catalog/equipment`} class="px-3 py-2 text-xs font-medium text-brand-slate-700 hover:bg-brand-steel-50 hover:text-brand-steel-700 rounded-md transition-colors" role="menuitem">9. Laboratory Equipment</a>
              </div>
            </div>
          </div>
          <a href={`${base}/about`} class="text-sm font-medium text-brand-slate-600 hover:text-brand-steel-600 transition-colors duration-200" aria-current={Astro.url.pathname === '/about' ? 'page' : undefined}>
            About
          </a>
          <a href={`${base}/quote`} class="inline-flex items-center justify-center px-4 py-2 text-xs font-semibold text-white bg-brand-steel-600 rounded-md hover:bg-brand-steel-700 transition-all duration-200 shadow-sm">
            Request Quote
          </a>
        </nav>

        <!-- Mobile Menu Toggle Button -->
        <button id="mobile-menu-toggle" class="md:hidden p-2 text-brand-slate-600 hover:text-brand-slate-950 focus:outline-none transition-colors" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden md:hidden border-t border-brand-slate-100 bg-white" role="navigation" aria-label="Mobile navigation">
        <div class="px-4 pt-2 pb-6 space-y-3">
          <a href={`${base}/`} class="block px-3 py-2.5 text-sm font-medium text-brand-slate-700 hover:bg-brand-slate-50 rounded-md">Home</a>
          <div class="px-3 py-1 text-xs font-bold text-brand-slate-400 uppercase tracking-widest">Categories</div>
          <div class="grid grid-cols-1 gap-1 pl-3">
            <a href={`${base}/catalog/glassware`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">1. Glassware</a>
            <a href={`${base}/catalog/porcelainware`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">2. Porcelainware</a>
            <a href={`${base}/catalog/silicaware`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">3. Silicaware</a>
            <a href={`${base}/catalog/plasticware`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">4. Plasticware</a>
            <a href={`${base}/catalog/sundries`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">5. Laboratory Sundries</a>
            <a href={`${base}/catalog/safety`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">6. Laboratory Safety</a>
            <a href={`${base}/catalog/paper`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">7. Paper Products</a>
            <a href={`${base}/catalog/liquid`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">8. Liquid Handling</a>
            <a href={`${base}/catalog/equipment`} class="px-3 py-2.5 text-xs font-medium text-brand-slate-600 hover:bg-brand-slate-50 rounded-md">9. Laboratory Equipment</a>
          </div>
          <div class="border-t border-brand-slate-100 pt-3 space-y-2">
            <a href={`${base}/about`} class="block px-3 py-2.5 text-sm font-medium text-brand-slate-700 hover:bg-brand-slate-50 rounded-md">About Us</a>
            <a href={`${base}/quote`} class="block text-center px-4 py-3 text-sm font-semibold text-white bg-brand-steel-600 rounded-md hover:bg-brand-steel-700 transition-all duration-200 shadow-sm">
              Request Quote
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow" role="main">
      <slot />
    </main>

    <!-- Global Footer -->
    <footer class="bg-brand-slate-950 text-brand-slate-400 border-t border-brand-slate-900 pt-16 pb-8 px-4 md:px-8" role="contentinfo">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-12">
          <!-- Corporate Column -->
          <div class="flex flex-col space-y-4">
            <a href={`${base}/`} class="flex items-center gap-2 select-none group">
              <img 
                src={`${base}/images/logo-icon.png`} 
                alt="MF Chemicals logo icon" 
                class="h-8 w-auto object-contain transition-opacity group-hover:opacity-90"
                width="32"
                height="32"
              />
              <div class="flex flex-col">
                <span class="text-sm font-bold tracking-tight text-white leading-tight">
                  MF CHEMICALS
                </span>
                <span class="text-[8px] uppercase tracking-widest text-brand-slate-400 font-semibold leading-none">
                  Scientific Supplies & Services
                </span>
              </div>
            </a>
            <p class="text-xs text-brand-slate-500 leading-relaxed max-w-sm">
              Established in 1985 in Penang, Malaysia. We specialize in B2B laboratory equipment, custom glassware, high-grade porcelain, and premium chemical supplies supporting industrial, scientific, and healthcare institutions.
            </p>
            <div class="flex items-center gap-3 pt-2 text-brand-slate-500">
              <span class="text-xs">© 2026 MF Chemicals Sdn Bhd. All rights reserved.</span>
            </div>
          </div>

          <!-- Quick Navigation -->
          <div class="flex flex-col space-y-4">
            <nav aria-label="Footer category links">
              <h3 class="text-white font-semibold text-sm tracking-widest uppercase text-left mb-3">Category Links</h3>
              <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-xs">
                <a href={`${base}/catalog/glassware`} class="hover:text-brand-amber-300 transition-colors">Glassware</a>
                <a href={`${base}/catalog/porcelainware`} class="hover:text-brand-amber-300 transition-colors">Porcelainware</a>
                <a href={`${base}/catalog/silicaware`} class="hover:text-brand-amber-300 transition-colors">Silicaware</a>
                <a href={`${base}/catalog/plasticware`} class="hover:text-brand-amber-300 transition-colors">Plasticware</a>
                <a href={`${base}/catalog/sundries`} class="hover:text-brand-amber-300 transition-colors">Laboratory Sundries</a>
                <a href={`${base}/catalog/safety`} class="hover:text-brand-amber-300 transition-colors">Laboratory Safety</a>
                <a href={`${base}/catalog/paper`} class="hover:text-brand-amber-300 transition-colors">Paper Products</a>
                <a href={`${base}/catalog/liquid`} class="hover:text-brand-amber-300 transition-colors">Liquid Handling</a>
                <a href={`${base}/catalog/equipment`} class="hover:text-brand-amber-300 transition-colors">Laboratory Equipment</a>
              </div>
            </nav>
            <div>
              <h3 class="text-white font-semibold text-sm tracking-widest uppercase mb-3">Company</h3>
              <div class="flex flex-col gap-2 text-xs">
                <a href={`${base}/about`} class="hover:text-brand-amber-300 transition-colors">About Us</a>
                <a href={`${base}/quote`} class="hover:text-brand-amber-300 transition-colors">Request Quote</a>
              </div>
            </div>
          </div>

          <!-- Contact & Location Column -->
          <div class="flex flex-col space-y-4">
            <h3 class="text-white font-semibold text-sm tracking-widest uppercase">Penang Office & Warehouse</h3>
            <address class="flex flex-col space-y-2 text-xs leading-relaxed not-italic">
              <p class="text-brand-slate-300">
                No. 27, Lorong Asas Jaya 4,<br />
                Kawasan Industri Ringan Asas Jaya,<br />
                Bukit Minyak, 14100 Bukit Mertajam,<br />
                Penang, Malaysia.
              </p>
              <div class="pt-2 flex flex-col space-y-1">
                <span class="flex flex-wrap items-center gap-x-2 gap-y-0.5">
                  <span class="text-brand-slate-600">Tel:</span>
                  <a href="tel:+6045883440" class="hover:text-white transition-colors">+604-5883440</a>
                  <span class="text-brand-slate-700">/</span>
                  <a href="https://wa.me/60164270012" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">+6016-4270012 (WhatsApp)</a>
                </span>
                <span class="flex items-center gap-2">
                  <span class="text-brand-slate-600">Email:</span>
                  <a href="mailto:info@mfchemicals.net" class="hover:text-white transition-colors">info@mfchemicals.net</a>
                </span>
              </div>
              <a 
                href="https://share.google/R9pRawIdEr1h76Te1" 
                target="_blank" 
                rel="noopener noreferrer" 
                class="inline-flex items-center gap-1.5 text-xs font-semibold text-brand-steel-400 hover:text-brand-steel-300 transition-colors mt-2"
              >
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                Open in Google Maps
              </a>
            </address>
          </div>
        </div>

        <div class="border-t border-brand-slate-900/60 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-brand-slate-600">
          <p>Institutional B2B Scientific Laboratory Supplies & Services Provider.</p>
        </div>
      </div>
    </footer>

    <!-- Global Inquiry Modal -->
    <InquiryModal />

    <!-- Sitewide Organization Schema -->
    <JsonLd data={organizationSchema} />

    <!-- Page-specific JSON-LD (passed from individual pages) -->
    {jsonLd && <JsonLd data={jsonLd} />}

    <!-- Vanilla Script for Menu Toggle -->
    <script>
      // Mobile menu functionality
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');

      if (toggleBtn && mobileMenu && hamburgerIcon) {
        toggleBtn.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          if (isHidden) {
            mobileMenu.classList.remove('hidden');
            hamburgerIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X icon
            toggleBtn.setAttribute('aria-expanded', 'true');
          } else {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); // Hamburger icon
            toggleBtn.setAttribute('aria-expanded', 'false');
          }
        });
      }
    </script>
  </body>
</html>
