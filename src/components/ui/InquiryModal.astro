---
import CloseIcon from '../icons/CloseIcon.astro';

// Placeholder key. Users can configure this in hosting environment variables or replace it.
const defaultKey = "YOUR_WEB3FORMS_ACCESS_TOKEN";
---

<dialog id="rfq-dialog" class="bg-white border border-brand-slate-200 rounded-xl shadow-premium max-w-lg w-[calc(100%-2rem)] md:w-full p-0 overflow-hidden outline-none backdrop:bg-brand-slate-950/50 backdrop:backdrop-blur-sm scale-95 opacity-0 transition-all duration-300 open:scale-100 open:opacity-100 mx-auto my-auto select-none">
  <!-- Modal Header -->
  <div class="px-6 py-5 border-b border-brand-slate-100 flex justify-between items-center bg-brand-slate-50">
    <div class="flex flex-col">
      <h2 class="text-base font-bold text-brand-slate-900 tracking-tight">Request for Quote</h2>
      <p class="text-xs text-brand-slate-500">Provide details for your pricing and availability inquiry.</p>
    </div>
    <button id="close-rfq-dialog" class="p-1.5 text-brand-slate-400 hover:text-brand-slate-900 rounded-md transition-colors focus:outline-none" aria-label="Close dialog">
      <CloseIcon class="w-5 h-5" />
    </button>
  </div>

  <!-- Form Body -->
  <div class="px-6 py-6 overflow-y-auto max-h-[75vh]">
    <!-- Success Message (hidden by default) -->
    <div id="rfq-success" class="hidden flex-col items-center justify-center text-center py-10 space-y-4 fade-in">
      <div class="w-12 h-12 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h3 class="text-base font-bold text-brand-slate-900">RFQ Received</h3>
      <p class="text-xs text-brand-slate-500 max-w-xs mx-auto">
        Thank you for your interest. A sales representative from MF Chemicals will contact you within 24 business hours.
      </p>
      <button id="close-success-btn" class="px-4 py-2 text-xs font-semibold text-white bg-brand-steel-600 rounded-md hover:bg-brand-steel-700 transition-all duration-200">
        Close Window
      </button>
    </div>

    <!-- Error Message (hidden by default) -->
    <div id="rfq-error" class="hidden flex-col items-center justify-center text-center py-6 space-y-3 bg-rose-50 border border-rose-100 rounded-lg p-4 mb-4 fade-in">
      <span class="text-xs font-semibold text-rose-800">Submission Failure</span>
      <p id="rfq-error-text" class="text-[11px] text-rose-600">Please verify your internet connection and try again.</p>
    </div>

    <form id="rfq-form" class="space-y-4">
      <!-- Web3Forms Config -->
      <input type="hidden" name="access_key" value={defaultKey} />
      <input type="hidden" name="subject" value="New RFQ Inquiry - MF Chemicals" />
      <input type="hidden" name="from_name" value="MF Chemicals Static Showcase" />

      <!-- Form Inputs -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="rfq-name" class="block text-xs font-semibold text-brand-slate-700 mb-1">Full Name <span class="text-rose-500">*</span></label>
          <input type="text" id="rfq-name" name="name" required class="w-full text-xs px-3 py-2.5 border border-brand-slate-200 rounded-md bg-white text-brand-slate-900 focus:outline-none focus:border-brand-slate-900 focus:ring-1 focus:ring-brand-slate-900/10 placeholder:text-brand-slate-400 transition-colors" placeholder="e.g. John Doe" />
        </div>
        <div>
          <label for="rfq-company" class="block text-xs font-semibold text-brand-slate-700 mb-1">Company / Institution <span class="text-rose-500">*</span></label>
          <input type="text" id="rfq-company" name="company" required class="w-full text-xs px-3 py-2.5 border border-brand-slate-200 rounded-md bg-white text-brand-slate-900 focus:outline-none focus:border-brand-slate-900 focus:ring-1 focus:ring-brand-slate-900/10 placeholder:text-brand-slate-400 transition-colors" placeholder="e.g. Penang Research Lab" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="rfq-email" class="block text-xs font-semibold text-brand-slate-700 mb-1">Business Email <span class="text-rose-500">*</span></label>
          <input type="email" id="rfq-email" name="email" required class="w-full text-xs px-3 py-2.5 border border-brand-slate-200 rounded-md bg-white text-brand-slate-900 focus:outline-none focus:border-brand-slate-900 focus:ring-1 focus:ring-brand-slate-900/10 placeholder:text-brand-slate-400 transition-colors" placeholder="e.g. johndoe@company.com" />
        </div>
        <div>
          <label for="rfq-phone" class="block text-xs font-semibold text-brand-slate-700 mb-1">Contact Number</label>
          <input type="tel" id="rfq-phone" name="phone" class="w-full text-xs px-3 py-2.5 border border-brand-slate-200 rounded-md bg-white text-brand-slate-900 focus:outline-none focus:border-brand-slate-900 focus:ring-1 focus:ring-brand-slate-900/10 placeholder:text-brand-slate-400 transition-colors" placeholder="e.g. +6012-3456789" />
        </div>
      </div>

      <div>
        <label for="rfq-category" class="block text-xs font-semibold text-brand-slate-700 mb-1">Interested Category</label>
        <select id="rfq-category" name="category" class="w-full text-xs px-3 py-2.5 border border-brand-slate-200 rounded-md bg-white text-brand-slate-900 focus:outline-none focus:border-brand-slate-900 focus:ring-1 focus:ring-brand-slate-900/10 transition-colors">
          <option value="General Inquiry">General Inquiry</option>
          <option value="Glassware">1. Glassware</option>
          <option value="Porcelainware">2. Porcelainware</option>
          <option value="Chemicals">3. Chemicals</option>
          <option value="Plasticware">4. Plasticware</option>
          <option value="Laboratory Sundries">5. Laboratory Sundries</option>
          <option value="Laboratory Safety">6. Laboratory Safety</option>
          <option value="Paper Products">7. Paper Products</option>
          <option value="Liquid Handling">8. Liquid Handling</option>
          <option value="Laboratory Equipment">9. Laboratory Equipment</option>
        </select>
      </div>

      <div>
        <label for="rfq-message" class="block text-xs font-semibold text-brand-slate-700 mb-1">Message & Item Details <span class="text-rose-500">*</span></label>
        <textarea id="rfq-message" name="message" required rows="4" class="w-full text-xs px-3 py-2.5 border border-brand-slate-200 rounded-md bg-white text-brand-slate-900 focus:outline-none focus:border-brand-slate-900 focus:ring-1 focus:ring-brand-slate-900/10 placeholder:text-brand-slate-400 transition-colors" placeholder="Please list specific items, brand preferences, volume/quantities, and any technical parameters required."></textarea>
      </div>

      <div class="pt-2">
        <button type="submit" id="rfq-submit-btn" class="w-full inline-flex items-center justify-center px-4 py-3 text-xs font-bold text-white bg-brand-steel-600 rounded-md hover:bg-brand-steel-700 transition-all duration-200 focus:outline-none">
          <span id="rfq-btn-text">Submit Request</span>
          <svg id="rfq-spinner" class="hidden animate-spin ml-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </div>
    </form>
  </div>
</dialog>

<script>
  // Handle dialog opening and submissions
  const dialog = document.getElementById('rfq-dialog') as HTMLDialogElement;
  const form = document.getElementById('rfq-form') as HTMLFormElement;
  const closeBtn = document.getElementById('close-rfq-dialog');
  const closeSuccessBtn = document.getElementById('close-success-btn');
  const submitBtn = document.getElementById('rfq-submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('rfq-btn-text');
  const spinner = document.getElementById('rfq-spinner');
  const successMessage = document.getElementById('rfq-success');
  const errorMessage = document.getElementById('rfq-error');
  const errorText = document.getElementById('rfq-error-text');

  // Trigger elements across the site (currently unused — all CTAs route to /quote page)
  const setupTriggers = () => {
    // Modal is retained for future use. Current CTAs link to /quote.
  };

  // Close operations
  const closeDialog = () => {
    dialog?.close();
  };

  closeBtn?.addEventListener('click', closeDialog);
  closeSuccessBtn?.addEventListener('click', closeDialog);
  
  // Close when clicking outer backdrop
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) {
      closeDialog();
    }
  });

  // AJAX submission to Web3Forms
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !btnText || !spinner || !successMessage || !errorMessage) return;

    submitBtn.disabled = true;
    btnText.textContent = "Sending...";
    spinner.classList.remove('hidden');
    errorMessage.classList.add('hidden');

    const formData = new FormData(form);
    
    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Accept': 'application/json'
        },
        body: formData
      });

      const json = await response.json();

      if (response.status === 200 || json.success) {
        // Success
        form.classList.add('hidden');
        successMessage.classList.remove('hidden');
      } else {
        // Error returned from server
        errorMessage.classList.remove('hidden');
        if (errorText) errorText.textContent = json.message || "Failed to accept submission on server.";
        submitBtn.disabled = false;
      }
    } catch (err) {
      // Network error
      errorMessage.classList.remove('hidden');
      if (errorText) errorText.textContent = "Network error. Please inspect connection and submit again.";
      submitBtn.disabled = false;
    } finally {
      btnText.textContent = "Submit Request";
      spinner.classList.add('hidden');
    }
  });

  // Run triggers setup on load
  setupTriggers();
  document.addEventListener('astro:after-swap', setupTriggers); // compatible with transitions
</script>
