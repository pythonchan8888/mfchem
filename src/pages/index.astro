---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { iconMap, type CategoryIconKey } from '../utils/icons';
import { base } from '../utils/base';

// Fetch all catalog items
const categories = await getCollection('catalog');

// Helper: extract subcategory name regardless of format (string or object)
const getSubName = (sub: string | { name: string; description: string }) =>
  typeof sub === 'string' ? sub : sub.name;

// LocalBusiness + WebSite structured data for homepage
const homepageJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "MF Chemicals Sdn Bhd",
    "image": `${new URL(`${base}/images/og-social-preview.jpg`, Astro.site)}`,
    "url": "https://www.mfchemicals.net",
    "@id": "https://www.mfchemicals.net/#localbusiness",
    "telephone": "+604-5883440",
    "email": "info@mfchemicals.net",
    "description": "Wholesale B2B supplier of institutional-grade scientific labware, laboratory equipment, and consumable supplies. Established 1985 in Penang, Malaysia.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "No. 27, Lorong Asas Jaya 4, Kawasan Industri Ringan Asas Jaya",
      "addressLocality": "Bukit Minyak, Bukit Mertajam",
      "addressRegion": "Penang",
      "postalCode": "14100",
      "addressCountry": "MY"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 5.3299,
      "longitude": 100.4587
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:30",
      "closes": "17:30"
    },
    "priceRange": "$$",
    "areaServed": {
      "@type": "Country",
      "name": "Malaysia"
    },
    "knowsAbout": [
      "Laboratory Glassware",
      "Scientific Equipment",
      "Laboratory Safety Equipment",
      "Liquid Handling Instruments",
      "Filter Papers",
      "Porcelain Labware"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MF Chemicals",
    "url": "https://www.mfchemicals.net"
  }
];
---

<Layout title="Home" description="MF Chemicals Sdn Bhd (Est. 1985) - Premium B2B Scientific Supplies, Laboratory Equipment & Custom Services based in Penang, Malaysia." jsonLd={homepageJsonLd}>
  
  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-16 md:py-32">
    <!-- Visual background grid decoration -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-60"></div>
    
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
      <!-- Trust Badge -->
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold text-brand-steel-700 bg-brand-steel-50 border border-brand-steel-200/50 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-steel-500"></span>
        Trusted Local B2B Partner Since 1985
      </span>

      <!-- Headline -->
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-brand-slate-900 max-w-4xl leading-[1.1] mb-6">
        Institutional-Grade <br class="hidden sm:inline" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-slate-900 via-brand-steel-800 to-brand-steel-600">Scientific Labware & Supplies</span>
      </h1>

      <!-- Subhead -->
      <p class="text-sm md:text-base text-brand-slate-500 max-w-2xl leading-relaxed mb-10">
        For over 40 years, MF Chemicals has supplied research facilities, testing labs, manufacturing plants, and educational institutions in Penang and across Malaysia with certified glassware, apparatus, and equipment.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <Button href="#categories-grid" variant="primary" size="lg" class="shadow-sm !bg-brand-steel-600 hover:!bg-brand-steel-700">
          Browse Categories
        </Button>
        <a href={`${base}/quote`} class="inline-flex items-center justify-center px-7 py-3 text-sm md:text-base font-semibold rounded-md border border-brand-slate-300 bg-transparent text-brand-slate-700 hover:bg-brand-slate-50 hover:text-brand-slate-950 focus:ring-2 focus:ring-brand-slate-100 active:bg-brand-slate-100 transition-all duration-200 shadow-sm">
          Request RFQ / Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Visual Product Collage -->
  <section class="relative bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-2 md:pt-4 pb-6 md:pb-8">
      <img 
        src={`${base}/images/hero-collage.jpg`} 
        alt="MF Chemicals laboratory supplies — glassware, equipment, porcelainware, plasticware, safety gear, and consumables for research and industrial labs" 
        class="w-full h-auto max-h-[350px] md:max-h-[450px] rounded-xl border border-brand-slate-200 shadow-premium object-cover object-[center_80%]"
        loading="eager"
        width="1200"
        height="450"
      />
    </div>
  </section>

  <!-- Categories Showcase Section -->
  <section id="categories-grid" class="py-12 md:py-24 bg-brand-slate-50 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="max-w-3xl mx-auto text-center mb-10 md:mb-20">
        <h2 class="text-2xl md:text-3xl font-bold text-brand-slate-900 tracking-tight">Our 9 Core Categories</h2>
        <div class="w-12 h-0.5 bg-brand-steel-500 mx-auto my-4"></div>
        <p class="text-xs md:text-sm text-brand-slate-500 leading-relaxed">
          Select a category to view subcategory details, catalog page references, represented premium brands, and submit specific inquiries.
        </p>
      </div>

      <!-- Categories Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {categories.map((category) => {
          const IconComponent = iconMap[category.data.icon as CategoryIconKey];
          
          return (
            <article class="group">
              <a 
                href={`${base}/catalog/${category.id}`} 
                class="block bg-white border border-brand-slate-200/80 rounded-xl overflow-hidden shadow-premium hover:shadow-premium-hover hover:border-brand-slate-300/80 transition-all duration-300 transform hover:-translate-y-1 select-none h-full"
                id={`category-card-${category.id}`}
              >
                {/* Product Thumbnail Header */}
                <div class="relative h-32 bg-gradient-to-b from-brand-slate-50 to-brand-slate-100/50 flex items-center justify-center overflow-hidden border-b border-brand-slate-100/60">
                  <img 
                    src={`${base}/images/banners/${category.id}.png`}
                    alt={`${category.data.title} products`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    width="400"
                    height="128"
                  />
                </div>

                <div class="p-6 lg:p-8">
                  {/* Card Header */}
                  <div class="flex items-center justify-between mb-5">
                    <div class="p-3 bg-brand-slate-50 rounded-lg group-hover:bg-brand-steel-600 group-hover:text-white transition-all duration-300">
                      {IconComponent && <IconComponent class="w-6 h-6" />}
                    </div>
                  </div>

                  {/* Card Title & Description */}
                  <h3 class="text-base font-bold text-brand-slate-900 group-hover:text-brand-slate-950 mb-2">
                    {category.data.title}
                  </h3>
                  <p class="text-xs text-brand-slate-500 leading-relaxed mb-6 line-clamp-3">
                    {category.data.description}
                  </p>

                  {/* Card Subcategories Preview */}
                  <div class="border-t border-brand-slate-100 pt-5">
                    <h4 class="text-[10px] uppercase font-bold tracking-widest text-brand-slate-400 mb-3">Sub-Categories Include</h4>
                    <div class="flex flex-wrap gap-1.5">
                      {category.data.subcategories.slice(0, 3).map((sub) => (
                        <span class="text-[10px] text-brand-slate-600 bg-brand-slate-50 px-2 py-0.5 rounded border border-brand-slate-100">
                          {getSubName(sub)}
                        </span>
                      ))}
                      {category.data.subcategories.length > 3 && (
                        <span class="text-[10px] text-brand-slate-400 bg-transparent px-1 py-0.5">
                          +{category.data.subcategories.length - 3} more
                        </span>
                      )}
                    </div>
                  </div>

                  {/* Action Link visual indicator */}
                  <div class="flex items-center gap-1.5 text-xs font-semibold text-brand-steel-600 group-hover:text-brand-steel-700 mt-6 pt-2 border-t border-brand-slate-50/50">
                    <span>View Range Details</span>
                    <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Social Proof Trust Strip -->
  <section class="bg-brand-steel-700 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-10">
        <p class="text-lg md:text-2xl font-bold text-white tracking-wide">
          Trusted by <span class="text-brand-steel-200 font-extrabold">500+ institutions</span> across Penang & Malaysia since 1985
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3 md:gap-5">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-steel-800/60 border border-brand-steel-500/30">
          <svg class="w-3.5 h-3.5 text-brand-steel-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
          </svg>
          <span class="text-[11px] font-medium text-brand-steel-100">Government Research Labs</span>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-steel-800/60 border border-brand-steel-500/30">
          <svg class="w-3.5 h-3.5 text-brand-steel-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342" />
          </svg>
          <span class="text-[11px] font-medium text-brand-steel-100">Universities & Polytechnics</span>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-steel-800/60 border border-brand-steel-500/30">
          <svg class="w-3.5 h-3.5 text-brand-steel-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />
          </svg>
          <span class="text-[11px] font-medium text-brand-steel-100">Semiconductor & Manufacturing</span>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-steel-800/60 border border-brand-steel-500/30">
          <svg class="w-3.5 h-3.5 text-brand-steel-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
          </svg>
          <span class="text-[11px] font-medium text-brand-steel-100">Pharmaceutical & QC Testing</span>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-steel-800/60 border border-brand-steel-500/30">
          <svg class="w-3.5 h-3.5 text-brand-steel-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
          </svg>
          <span class="text-[11px] font-medium text-brand-steel-100">Private Testing Laboratories</span>
        </div>
      </div>
    </div>
  </section>

  <!-- B2B Trust Pillars Section -->
  <section class="py-12 md:py-24 bg-white border-t border-b border-brand-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
        <div class="space-y-4">
          <div class="flex justify-center md:justify-start">
            <svg class="w-10 h-10 text-brand-steel-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a1.5 1.5 0 002.122 0l4.318-4.318a1.5 1.5 0 000-2.122L11.16 3.659A2.25 2.25 0 009.568 3z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
            </svg>
          </div>
          <div class="text-brand-slate-900 font-bold text-lg">01. B2B Pricing Structure</div>
          <p class="text-xs text-brand-slate-500 leading-relaxed">
            We operate strictly as a wholesale B2B scientific vendor, offering bulk discounting and custom quotation structures for corporate procurement teams and research organizations.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex justify-center md:justify-start">
            <svg class="w-10 h-10 text-brand-steel-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21a3.745 3.745 0 01-3.068-1.593 3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <div class="text-brand-slate-900 font-bold text-lg">02. Verified Global Brands</div>
          <p class="text-xs text-brand-slate-500 leading-relaxed">
            Every product supplied comes with certification. We represent leading industry brands (Pyrex, MBL, Socorex, Whatman, Memmert, Ansell) guaranteeing regulatory compliance and consistency.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex justify-center md:justify-start">
            <svg class="w-10 h-10 text-brand-steel-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <div class="text-brand-slate-900 font-bold text-lg">03. Local Logistic Hub</div>
          <p class="text-xs text-brand-slate-500 leading-relaxed">
            Located in Bukit Minyak, Penang's industrial area. We maintain local stock levels of high-turnover consumables, supporting quick dispatch and self-collection coordinates for local clients.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="py-16 md:py-24 bg-white border-b border-brand-slate-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 flex justify-center">
          <div class="relative w-full max-w-sm">
            <img 
              src={`${base}/images/about/about-office.jpeg`} 
              alt="MF Chemicals Penang office — direct B2B service since 1985" 
              class="w-full h-auto rounded-2xl border border-brand-slate-200 shadow-premium object-cover aspect-[4/3]"
              width="600"
              height="450"
              loading="lazy"
            />
            <div class="absolute -bottom-2 -right-2 bg-brand-steel-600 text-white rounded-lg px-3 py-1.5 shadow-premium text-xs font-bold">
              Est. 1985
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2 space-y-5">
          <div>
            <span class="text-[10px] uppercase font-bold tracking-widest text-brand-steel-600">Our Story</span>
            <h2 class="text-2xl md:text-3xl font-bold text-brand-slate-900 tracking-tight mt-2">Family-Run Since 1985</h2>
            <div class="w-10 h-0.5 bg-brand-steel-500 mt-4"></div>
          </div>
          <p class="text-sm text-brand-slate-600 leading-relaxed">
            For over four decades, MF Chemicals has been a family-run cornerstone of Penang's scientific supply chain. What started as a modest glassware distributor in Bukit Mertajam is now a trusted B2B partner to universities, testing labs, and manufacturing plants across Malaysia.
          </p>
          <p class="text-sm text-brand-slate-600 leading-relaxed">
            No corporate layers. When you call us, you speak to someone who can make decisions — because we're still family-owned, still hands-on, and still care about every order that ships from our Penang warehouse.
          </p>
          <a 
            href={`${base}/about`} 
            class="inline-flex items-center gap-1.5 text-sm font-bold text-brand-steel-600 hover:text-brand-steel-700 transition-colors"
          >
            Learn more about MF Chemicals
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Callout -->
  <section class="py-20 bg-brand-slate-950 text-white relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 text-center space-y-6 relative z-10">
      <h2 class="text-2xl md:text-4xl font-bold tracking-tight">Need a Custom Quote or Special Consumables?</h2>
      <p class="text-xs md:text-sm text-brand-slate-400 max-w-xl mx-auto leading-relaxed">
        Our sales representatives are ready to assist. Contact our Bukit Minyak office directly or submit an RFQ form with item specifications.
      </p>
      <div class="pt-4 flex flex-col sm:flex-row justify-center gap-4">
        <a href={`${base}/quote`} class="inline-flex items-center justify-center px-6 py-3 text-xs font-bold text-white bg-brand-steel-500 hover:bg-brand-steel-600 rounded-md transition-colors shadow-sm">
          Submit RFQ Form
        </a>
        <a href="tel:+6045883440" class="inline-flex items-center justify-center px-6 py-3 text-xs font-bold text-brand-slate-400 border border-brand-slate-700 hover:border-brand-slate-500 hover:text-brand-slate-300 rounded-md transition-colors">
          Call: +604-5883440
        </a>
      </div>
    </div>
  </section>

</Layout>


