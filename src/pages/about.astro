---
import Layout from '../layouts/Layout.astro';
import { base } from '../utils/base';

const aboutJsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About MF Chemicals",
  "description": "MF Chemicals Sdn Bhd — a family-run B2B scientific supplies company established in 1985 in Bukit Minyak, Penang, Malaysia.",
  "mainEntity": {
    "@type": "Organization",
    "name": "MF Chemicals Sdn Bhd",
    "foundingDate": "1985",
    "founder": {
      "@type": "Person",
      "name": "Chan Family"
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "No. 27, Lorong Asas Jaya 4, Kawasan Industri Ringan Asas Jaya",
      "addressLocality": "Bukit Minyak, Bukit Mertajam",
      "addressRegion": "Penang",
      "postalCode": "14100",
      "addressCountry": "MY"
    }
  }
};
---

<Layout 
  title="About Us" 
  description="MF Chemicals Sdn Bhd — Penang's trusted B2B scientific supplies partner since 1985. Family-run, serving research labs, manufacturing plants, and educational institutions across Malaysia."
  jsonLd={aboutJsonLd}
>
  <!-- Hero Banner -->
  <section class="relative bg-brand-slate-950 text-white overflow-hidden py-20 md:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(46,91,140,0.3),transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold text-brand-amber-300 bg-brand-amber-950/50 border border-brand-amber-800/30 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-amber-400"></span>
        Established 1985
      </span>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">
        Four Decades of Trust in<br class="hidden sm:inline" />
        <span class="text-brand-amber-300">Scientific Supply</span>
      </h1>
      <p class="text-sm md:text-base text-brand-slate-300 max-w-2xl mx-auto leading-relaxed">
        What began as a modest glassware distributor in Penang has grown into one of Malaysia's most trusted B2B laboratory supply houses — serving universities, testing labs, and manufacturing plants nationwide.
      </p>
    </div>
  </section>

  <!-- Motto Quote -->
  <section class="py-12 md:py-16 bg-white border-b border-brand-slate-100">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="flex items-center justify-center gap-4 mb-2">
        <div class="h-px w-12 bg-brand-slate-200"></div>
        <span class="text-brand-slate-300">◆</span>
        <div class="h-px w-12 bg-brand-slate-200"></div>
      </div>
      <blockquote class="text-2xl md:text-4xl font-light tracking-wide text-brand-slate-800 italic leading-relaxed">
        &#8220;Do It Right The First Time&#8221;
      </blockquote>
      <p class="text-xs text-brand-slate-400 mt-4 uppercase tracking-widest font-semibold">MF Chemicals</p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-center">
        <!-- Text -->
        <div class="lg:col-span-3 space-y-6">
          <div>
            <span class="text-[10px] uppercase font-bold tracking-widest text-brand-steel-600">Our Story</span>
            <h2 class="text-2xl md:text-3xl font-bold text-brand-slate-900 tracking-tight mt-2">From Penang to Malaysia</h2>
            <div class="w-10 h-0.5 bg-brand-steel-500 mt-4"></div>
          </div>
          
          <p class="text-sm text-brand-slate-600 leading-relaxed">
            MF Chemicals was founded in 1985 in Bukit Minyak, Penang — right in the heart of Malaysia's northern industrial corridor. For over 40 years, we've supplied research facilities, testing laboratories, manufacturing plants, and educational institutions with certified scientific glassware, laboratory equipment, and consumable supplies.
          </p>
          
          <p class="text-sm text-brand-slate-600 leading-relaxed">
            We remain a <strong class="text-brand-slate-800">family-run business</strong> at our core. That means procurement officers and lab managers deal directly with decision-makers — not layers of corporate bureaucracy. When you need a custom order, technical consultation, or urgent restock, you speak to someone who can actually make it happen.
          </p>

          <p class="text-sm text-brand-slate-600 leading-relaxed">
            Today, we represent <strong class="text-brand-slate-800">premium global brands</strong> including Pyrex, MBL, Duran, Socorex, Whatman, Memmert, Ohaus, Mettler Toledo, and Ansell — bringing world-class laboratory standards to Malaysian institutions at competitive B2B pricing.
          </p>
        </div>

        <!-- Visual -->
        <div class="lg:col-span-2 flex justify-center">
          <div class="relative w-full max-w-sm">
            <img 
              src={`${base}/images/about/about-warehouse.jpeg`} 
              alt="MF Chemicals warehouse in Bukit Minyak, Penang — family-run B2B laboratory supplies since 1985" 
              class="w-full h-auto rounded-2xl border border-brand-slate-200 shadow-premium object-cover aspect-[4/3]"
              width="600"
              height="450"
              loading="lazy"
            />
            <div class="absolute -bottom-3 -right-3 bg-brand-steel-600 text-white rounded-lg px-4 py-2 shadow-premium text-xs font-bold">
              Est. 1985
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Supply -->
  <section class="py-16 md:py-24 bg-brand-slate-50 border-y border-brand-slate-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-[10px] uppercase font-bold tracking-widest text-brand-steel-600">What We Supply</span>
        <h2 class="text-2xl md:text-3xl font-bold text-brand-slate-900 tracking-tight mt-2">9 Core Product Categories</h2>
        <div class="w-10 h-0.5 bg-brand-steel-500 mx-auto mt-4"></div>
        <p class="text-xs md:text-sm text-brand-slate-500 mt-4 max-w-xl mx-auto">
          Every product category is backed by authorized distribution agreements and full documentation support — MSDS, calibration certificates, and batch traceability.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { num: '01', name: 'Glassware', desc: 'Borosilicate & soda-lime glass. Pyrex, MBL, Duran, Quickfit.' },
          { num: '02', name: 'Porcelainware', desc: 'High-temperature refractory crucibles, basins & funnels.' },
          { num: '03', name: 'Silicaware', desc: 'Silicone tubing, stoppers, heating mantles & accessories.' },
          { num: '04', name: 'Plasticware', desc: 'Break-resistant, chemical-compatible plastic labware.' },
          { num: '05', name: 'Laboratory Sundries', desc: 'Brushes, clamps, stands, spatulas, tongs & tools.' },
          { num: '06', name: 'Laboratory Safety', desc: 'PPE, eyewash stations, lab coats, breathing protection.' },
          { num: '07', name: 'Paper Products', desc: 'Qualitative, quantitative filter papers & membrane filters.' },
          { num: '08', name: 'Liquid Handling', desc: 'Pipettors, dispensers, digital burettes from Socorex & more.' },
          { num: '09', name: 'Laboratory Equipment', desc: 'Balances, autoclaves, water distillers, fume cupboards.' }
        ].map(cat => (
          <div class="bg-white border border-brand-slate-200/60 rounded-lg p-5 flex items-start gap-4 hover:border-brand-slate-300 hover:shadow-premium transition-all">
            <span class="text-base font-bold text-brand-steel-500 shrink-0">{cat.num}</span>
            <div>
              <h3 class="text-sm font-bold text-brand-slate-800">{cat.name}</h3>
              <p class="text-[11px] text-brand-slate-500 leading-relaxed mt-1">{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-[10px] uppercase font-bold tracking-widest text-brand-steel-600">How We Work</span>
        <h2 class="text-2xl md:text-3xl font-bold text-brand-slate-900 tracking-tight mt-2">The MF Chemicals Difference</h2>
        <div class="w-10 h-0.5 bg-brand-steel-500 mx-auto mt-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Value 1 -->
        <div class="text-center space-y-4">
          <div class="w-14 h-14 bg-brand-steel-50 rounded-xl flex items-center justify-center mx-auto">
            <svg class="w-7 h-7 text-brand-steel-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-brand-slate-900">Authorized Distribution</h3>
          <p class="text-xs text-brand-slate-500 leading-relaxed">
            Every brand we carry comes with full manufacturer authorization. No grey-market stock. MSDS sheets, calibration certificates, and batch traceability documentation provided on request.
          </p>
        </div>

        <!-- Value 2 -->
        <div class="text-center space-y-4">
          <div class="w-14 h-14 bg-brand-steel-50 rounded-xl flex items-center justify-center mx-auto">
            <svg class="w-7 h-7 text-brand-steel-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-brand-slate-900">Local Stock & Fast Dispatch</h3>
          <p class="text-xs text-brand-slate-500 leading-relaxed">
            Our Bukit Minyak warehouse holds local inventory of high-turnover consumables. No waiting on international freight for common items — pick up same-day or next-day dispatch across Penang and West Malaysia.
          </p>
        </div>

        <!-- Value 3 -->
        <div class="text-center space-y-4">
          <div class="w-14 h-14 bg-brand-steel-50 rounded-xl flex items-center justify-center mx-auto">
            <svg class="w-7 h-7 text-brand-steel-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-brand-slate-900">Direct B2B Relationships</h3>
          <p class="text-xs text-brand-slate-500 leading-relaxed">
            We don't do retail. Every client — from university labs to multinational manufacturers — gets direct access to our procurement team, custom quotation, bulk pricing, and priority support.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Location Section -->
  <section class="py-16 md:py-24 bg-brand-slate-950 text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <div>
            <span class="text-[10px] uppercase font-bold tracking-widest text-brand-amber-400">Visit Us</span>
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight mt-2">Penang Office & Warehouse</h2>
            <div class="w-10 h-0.5 bg-brand-amber-500 mt-4"></div>
          </div>

          <address class="not-italic space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <p class="text-sm text-brand-slate-300 leading-relaxed">
                No. 27, Lorong Asas Jaya 4,<br />
                Kawasan Industri Ringan Asas Jaya,<br />
                Bukit Minyak, 14100 Bukit Mertajam,<br />
                Penang, Malaysia.
              </p>
            </div>

            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <div class="flex flex-col gap-1">
                <a href="tel:+6045883440" class="text-sm text-brand-slate-300 hover:text-white transition-colors">+604-5883440</a>
                <a href="https://wa.me/60164270012" target="_blank" rel="noopener noreferrer" class="text-sm text-brand-amber-400 hover:text-brand-amber-300 transition-colors">+6016-4270012 (WhatsApp)</a>
                <a href="mailto:info@mfchemicals.net" class="text-sm text-brand-slate-300 hover:text-white transition-colors">info@mfchemicals.net</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-sm text-brand-slate-300 leading-relaxed">
                Business Hours: Monday – Friday, 8:30 AM – 5:30 PM (GMT+8)<br />
                <span class="text-brand-slate-500 text-xs">Closed on weekends & Malaysian public holidays.</span>
              </p>
            </div>
          </address>
        </div>

        <!-- Location Visual -->
        <div class="rounded-xl overflow-hidden border border-brand-slate-800 shadow-premium">
          <img 
            src={`${base}/images/about/about-delivery.jpeg`} 
            alt="MF Chemicals delivery and logistics — local B2B dispatch from Bukit Minyak, Penang" 
            class="w-full h-auto object-cover aspect-[4/3]"
            width="600"
            height="450"
            loading="lazy"
          />
          <div class="bg-brand-slate-900 px-5 py-4">
            <p class="text-xs text-brand-slate-400 leading-relaxed">
              Located in Bukit Minyak Industrial Estate, Penang's northern manufacturing hub — accessible from North-South Expressway and Penang Bridge.
            </p>
            <a 
              href="https://share.google/R9pRawIdEr1h76Te1" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-xs font-semibold text-brand-steel-400 hover:text-brand-steel-300 transition-colors mt-2"
            >
              Open in Google Maps
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center space-y-6">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-slate-900 tracking-tight">Ready to Work Together?</h2>
      <p class="text-sm text-brand-slate-500 max-w-lg mx-auto leading-relaxed">
        Whether you need a single bulk order or a long-term procurement partnership, our team is ready to assist.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 pt-2">
        <a 
          href={`${base}/quote`} 
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-bold text-white bg-brand-steel-600 rounded-md hover:bg-brand-steel-700 transition-all duration-200 shadow-sm"
        >
          Request a Quote
        </a>
        <a 
          href={`${base}/catalog/glassware`} 
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-bold text-brand-slate-700 border border-brand-slate-300 rounded-md hover:bg-brand-slate-50 transition-all duration-200"
        >
          Browse Catalog
        </a>
      </div>
    </div>
  </section>
</Layout>
