---
import Layout from '../layouts/Layout.astro';
import { base } from '../utils/base';

const quoteJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Request for Quote — MF Chemicals",
  "description": "Submit a B2B pricing and availability inquiry to MF Chemicals Sdn Bhd. Bulk discounting and custom quotation for corporate procurement teams in Malaysia.",
  "provider": {
    "@type": "Organization",
    "name": "MF Chemicals Sdn Bhd",
    "url": "https://www.mfchemicals.net"
  }
};
---

<Layout 
  title="Request Quote" 
  description="Request a B2B quotation from MF Chemicals. Custom pricing, bulk discounting, and technical consultation for laboratory supplies and scientific equipment in Malaysia."
  jsonLd={quoteJsonLd}
>
  <div class="bg-brand-slate-50 min-h-screen py-10 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Page Header -->
      <div class="text-center mb-10">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold text-brand-steel-700 bg-brand-steel-50 border border-brand-steel-200/50 mb-4">
          B2B Procurement
        </span>
        <h1 class="text-2xl md:text-4xl font-bold tracking-tight text-brand-slate-900 mb-4">
          Request a Quote
        </h1>
        <p class="text-sm text-brand-slate-500 max-w-lg mx-auto leading-relaxed">
          Provide your item specifications below and our sales team will respond with pricing, availability, and delivery timelines — typically within 24 business hours.
        </p>
      </div>

      <!-- Form Card -->
      <div class="bg-white border border-brand-slate-200/80 rounded-xl shadow-premium overflow-hidden">
        <!-- Success Message (hidden by default) -->
        <div id="quote-success" class="hidden flex-col items-center justify-center text-center py-16 px-6 space-y-4 fade-in">
          <div class="w-16 h-16 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-600">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-slate-900">Inquiry Received</h3>
          <p class="text-sm text-brand-slate-500 max-w-sm mx-auto leading-relaxed">
            Thank you for your interest. A sales representative from MF Chemicals will contact you within 24 business hours with pricing and availability details.
          </p>
          <a href={`${base}/`} class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-brand-steel-600 rounded-md hover:bg-brand-steel-700 transition-colors mt-4">
            Return to Homepage
          </a>
        </div>

        <!-- Error Message -->
        <div id="quote-error" class="hidden bg-rose-50 border-b border-rose-100 px-6 py-4 text-center fade-in">
          <span class="text-xs font-semibold text-rose-800">Submission failed.</span>
          <p id="quote-error-text" class="text-[11px] text-rose-600 mt-1">Please check your connection and try again.</p>
        </div>

        <!-- Form -->
        <form id="quote-form" class="p-6 md:p-8 space-y-5">
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_TOKEN" />
          <input type="hidden" name="subject" value="New RFQ Inquiry - MF Chemicals" />
          <input type="hidden" name="from_name" value="MF Chemicals Quote Page" />

          <!-- Two-column row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="quote-name" class="block text-xs font-semibold text-brand-slate-700 mb-1.5">Full Name <span class="text-rose-500">*</span></label>
              <input type="text" id="quote-name" name="name" required 
                class="w-full text-sm px-4 py-3 border border-brand-slate-200 rounded-lg bg-white text-brand-slate-900 focus:outline-none focus:border-brand-steel-500 focus:ring-2 focus:ring-brand-steel-500/10 placeholder:text-brand-slate-400 transition-colors"
                placeholder="e.g. John Doe" />
            </div>
            <div>
              <label for="quote-company" class="block text-xs font-semibold text-brand-slate-700 mb-1.5">Company / Institution <span class="text-rose-500">*</span></label>
              <input type="text" id="quote-company" name="company" required 
                class="w-full text-sm px-4 py-3 border border-brand-slate-200 rounded-lg bg-white text-brand-slate-900 focus:outline-none focus:border-brand-steel-500 focus:ring-2 focus:ring-brand-steel-500/10 placeholder:text-brand-slate-400 transition-colors"
                placeholder="e.g. Universiti Sains Malaysia" />
            </div>
          </div>

          <!-- Two-column row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="quote-email" class="block text-xs font-semibold text-brand-slate-700 mb-1.5">Business Email <span class="text-rose-500">*</span></label>
              <input type="email" id="quote-email" name="email" required 
                class="w-full text-sm px-4 py-3 border border-brand-slate-200 rounded-lg bg-white text-brand-slate-900 focus:outline-none focus:border-brand-steel-500 focus:ring-2 focus:ring-brand-steel-500/10 placeholder:text-brand-slate-400 transition-colors"
                placeholder="e.g. johndoe@company.com" />
            </div>
            <div>
              <label for="quote-phone" class="block text-xs font-semibold text-brand-slate-700 mb-1.5">Contact Number</label>
              <input type="tel" id="quote-phone" name="phone" 
                class="w-full text-sm px-4 py-3 border border-brand-slate-200 rounded-lg bg-white text-brand-slate-900 focus:outline-none focus:border-brand-steel-500 focus:ring-2 focus:ring-brand-steel-500/10 placeholder:text-brand-slate-400 transition-colors"
                placeholder="e.g. +6012-3456789" />
            </div>
          </div>

          <!-- Category select -->
          <div>
            <label for="quote-category" class="block text-xs font-semibold text-brand-slate-700 mb-1.5">Interested Category</label>
            <select id="quote-category" name="category" 
              class="w-full text-sm px-4 py-3 border border-brand-slate-200 rounded-lg bg-white text-brand-slate-900 focus:outline-none focus:border-brand-steel-500 focus:ring-2 focus:ring-brand-steel-500/10 transition-colors">
              <option value="General Inquiry">General Inquiry</option>
              <option value="Glassware">1. Glassware</option>
              <option value="Porcelainware">2. Porcelainware</option>
              <option value="Chemicals">3. Chemicals</option>
              <option value="Plasticware">4. Plasticware</option>
              <option value="Laboratory Sundries">5. Laboratory Sundries</option>
              <option value="Laboratory Safety">6. Laboratory Safety</option>
              <option value="Paper Products">7. Paper Products</option>
              <option value="Liquid Handling">8. Liquid Handling</option>
              <option value="Laboratory Equipment">9. Laboratory Equipment</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="quote-message" class="block text-xs font-semibold text-brand-slate-700 mb-1.5">Item Details & Requirements <span class="text-rose-500">*</span></label>
            <textarea id="quote-message" name="message" required rows="5" 
              class="w-full text-sm px-4 py-3 border border-brand-slate-200 rounded-lg bg-white text-brand-slate-900 focus:outline-none focus:border-brand-steel-500 focus:ring-2 focus:ring-brand-steel-500/10 placeholder:text-brand-slate-400 transition-colors resize-y"
              placeholder="Please include: specific items needed, preferred brands, quantities, technical specifications, and any special requirements (e.g. ISO calibration certificates, delivery timeline)."></textarea>
          </div>

          <!-- Submit -->
          <div class="pt-2">
            <button type="submit" id="quote-submit-btn" 
              class="w-full inline-flex items-center justify-center px-6 py-3.5 text-sm font-bold text-white bg-brand-steel-600 rounded-lg hover:bg-brand-steel-700 active:bg-brand-steel-800 transition-all duration-200 shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-steel-500 focus:ring-offset-2">
              <span id="quote-btn-text">Submit Inquiry</span>
              <svg id="quote-spinner" class="hidden animate-spin ml-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>

      <!-- Alternative Contact Methods -->
      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="https://wa.me/60164270012" target="_blank" rel="noopener noreferrer" 
          class="bg-white border border-brand-slate-200/80 rounded-xl p-5 flex items-center gap-4 hover:border-emerald-300 hover:shadow-premium transition-all group">
          <div class="w-10 h-10 bg-emerald-50 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-emerald-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.37 5.028L2 22l5.13-1.346a9.921 9.921 0 004.882 1.28h.005c5.507 0 9.99-4.478 9.99-9.985C22.007 6.478 17.519 2 12.012 2zm0 1.794c4.512 0 8.187 3.67 8.188 8.186-.001 4.516-3.676 8.186-8.188 8.186a8.125 8.125 0 01-4.148-1.129l-.298-.176-3.084.808.823-3.003-.194-.308a8.127 8.127 0 01-1.296-4.384c.002-4.516 3.677-8.186 8.187-8.186zm-3.565 4.965c-.195-.434-.4-.442-.587-.45l-.499-.006c-.173 0-.455.065-.693.325-.238.26-1.077 1.053-1.077 2.569 0 1.515 1.103 2.977 1.254 3.179.152.202 2.127 3.396 5.27 4.636 2.613 1.031 3.144.826 3.71.77.567-.056 1.826-.747 2.085-1.47.259-.723.259-1.342.182-1.471-.077-.13-.284-.203-.594-.362s-1.827-.9-2.106-1.002c-.279-.101-.482-.152-.684.152-.202.304-.783.985-.96 1.187-.176.202-.353.228-.662.069a8.318 8.318 0 01-2.456-1.515 9.176 9.176 0 01-1.7-2.115c-.178-.304-.019-.469.136-.623.14-.139.31-.362.465-.543.155-.181.207-.304.31-.506.104-.203.052-.38-.026-.54-.078-.16-.587-1.472-.816-1.986z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-bold text-brand-slate-800 group-hover:text-brand-slate-900">WhatsApp Direct</h3>
            <p class="text-xs text-brand-slate-500 mt-0.5">+6016-4270012 &mdash; fastest response</p>
          </div>
        </a>

        <a href="mailto:info@mfchemicals.net" 
          class="bg-white border border-brand-slate-200/80 rounded-xl p-5 flex items-center gap-4 hover:border-brand-slate-300 hover:shadow-premium transition-all group">
          <div class="w-10 h-10 bg-brand-slate-100 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-brand-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-bold text-brand-slate-800 group-hover:text-brand-slate-900">Email Inquiry</h3>
            <p class="text-xs text-brand-slate-500 mt-0.5">info@mfchemicals.net</p>
          </div>
        </a>
      </div>

    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const submitBtn = document.getElementById('quote-submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('quote-btn-text');
  const spinner = document.getElementById('quote-spinner');
  const successMessage = document.getElementById('quote-success');
  const errorMessage = document.getElementById('quote-error');
  const errorText = document.getElementById('quote-error-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !btnText || !spinner || !successMessage || !errorMessage) return;

    submitBtn.disabled = true;
    btnText.textContent = "Sending...";
    spinner.classList.remove('hidden');
    errorMessage.classList.add('hidden');

    const formData = new FormData(form);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: formData
      });

      const json = await response.json();

      if (response.status === 200 || json.success) {
        form.classList.add('hidden');
        successMessage.classList.remove('hidden');
        successMessage.scrollIntoView({ behavior: 'smooth' });
      } else {
        errorMessage.classList.remove('hidden');
        if (errorText) errorText.textContent = json.message || "Server error. Please try again or contact us via WhatsApp.";
        submitBtn.disabled = false;
      }
    } catch (err) {
      errorMessage.classList.remove('hidden');
      if (errorText) errorText.textContent = "Network error. Please check your connection or reach us via WhatsApp.";
      submitBtn.disabled = false;
    } finally {
      btnText.textContent = "Submit Inquiry";
      spinner.classList.add('hidden');
    }
  });
</script>
