---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import { base } from '../utils/base';
---

<Layout title="Page Not Found" description="The catalog page or resource you are looking for does not exist. Please return to the homepage or submit an inquiry to the MF Chemicals team.">
  <div class="max-w-7xl mx-auto px-4 py-20 flex flex-col items-center justify-center text-center space-y-6 select-none min-h-[50vh]">
    <!-- Badge -->
    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold text-rose-800 bg-rose-50 border border-rose-100">
      Error 404
    </span>
    
    <!-- Big Title -->
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-brand-slate-900 leading-none">
      Resource Not Found
    </h1>
    
    <!-- Subhead -->
    <p class="text-xs md:text-sm text-brand-slate-500 max-w-md leading-relaxed">
      The catalog section, product category, or page path you attempted to access does not exist or has been relocated as part of a recent site update.
    </p>
    
    <!-- Action buttons -->
    <div class="pt-4 flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
      <Button href={`${base}/`} variant="primary" size="md">
        Return to Homepage
      </Button>
      <button id="open-rfq-404" class="inline-flex items-center justify-center px-5 py-2.5 text-xs md:text-sm font-semibold rounded-md border border-brand-slate-300 bg-transparent text-brand-slate-700 hover:bg-brand-slate-50 hover:text-brand-slate-950 focus:ring-2 focus:ring-brand-slate-100 active:bg-brand-slate-100 transition-all duration-200">
        Inquire Directly
      </button>
    </div>
  </div>
</Layout>

<script>
  // Dynamic dialog trigger for the 404 page
  const setup404Trigger = () => {
    const rfq404Btn = document.getElementById('open-rfq-404');
    const dialogElement = document.getElementById('rfq-dialog') as HTMLDialogElement;

    if (rfq404Btn && dialogElement) {
      rfq404Btn.addEventListener('click', () => {
        dialogElement.showModal();
      });
    }
  };

  setup404Trigger();
  document.addEventListener('astro:after-swap', setup404Trigger);
</script>
