---
import Layout from '../../layouts/Layout.astro';
import InquirePanel from '../../components/catalog/InquirePanel.astro';
import { getCollection } from 'astro:content';
import { iconMap, type CategoryIconKey } from '../../utils/icons';
import { base } from '../../utils/base';

// Dynamic static paths for 9 categories
export async function getStaticPaths() {
  const categories = await getCollection('catalog');
  return categories.map((cat) => ({
    params: { id: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const { title, description, subcategories, brands, catalogPages, icon } = category.data;

const IconComponent = iconMap[icon as CategoryIconKey];

// Helper: extract subcategory name regardless of format (string or object)
const getSubName = (sub: string | { name: string; description: string }) =>
  typeof sub === 'string' ? sub : sub.name;

// Helper: extract subcategory description (or generate a default)
const getSubDescription = (sub: string | { name: string; description: string }) =>
  typeof sub === 'string'
    ? `Premium ${sub} from brands like ${brands.join(', ')}. Available through MF Chemicals Penang.`
    : sub.description;

// Build page-specific JSON-LD: BreadcrumbList + Product/ItemList
const catalogPageJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": `${Astro.site}`
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Catalog",
        "item": `${Astro.site}catalog`
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": title,
        "item": `${new URL(`${base}/catalog/${category.id}`, Astro.site)}`
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `${title} — MF Chemicals Product Range`,
    "description": description,
    "numberOfItems": subcategories.length,
    "itemListElement": subcategories.map((sub, idx) => ({
      "@type": "ListItem",
      "position": idx + 1,
      "name": getSubName(sub),
      "description": getSubDescription(sub),
    })),
    "provider": {
      "@type": "Organization",
      "name": "MF Chemicals Sdn Bhd",
      "url": "https://www.mfchemicals.net"
    }
  }
];

const pageDescription = `MF Chemicals Penang (Est. 1985) - View our high-quality range of ${title} products including subcategories, representative brands: ${brands.join(', ')}.`;
---

<Layout 
  title={title} 
  description={pageDescription}
  jsonLd={catalogPageJsonLd}
>
  <div class="bg-brand-slate-50 min-h-screen py-6 md:py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <nav class="flex mb-8 text-xs font-semibold text-brand-slate-400 select-none" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-2" itemscope itemtype="https://schema.org/BreadcrumbList">
          <li class="inline-flex items-center" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href={`${base}/`} class="hover:text-brand-slate-700 transition-colors" itemprop="item"><span itemprop="name">Home</span></a>
            <meta itemprop="position" content="1" />
          </li>
          <li class="flex items-center" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <svg class="w-3 h-3 mx-1.5 text-brand-slate-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-brand-slate-400" itemprop="name">Catalog</span>
            <meta itemprop="position" content="2" />
          </li>
          <li class="flex items-center" aria-current="page" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <svg class="w-3 h-3 mx-1.5 text-brand-slate-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-brand-slate-700" itemprop="name">{title}</span>
            <meta itemprop="position" content="3" />
          </li>
        </ol>
      </nav>

      <!-- Category Page Header Banner -->
      <div class="relative bg-white border border-brand-slate-200/80 rounded-xl overflow-hidden mb-10 shadow-premium">
        <div class="flex flex-col md:flex-row items-center">
          <!-- Text and Info Content (Left Side) -->
          <div class="p-6 md:p-10 flex-grow flex flex-col justify-between gap-6 md:w-[60%]">
            <div class="space-y-4">
              <div class="flex items-center gap-4">
                <div class="p-3 bg-brand-steel-600 text-white rounded-lg shadow-sm shrink-0">
                  {IconComponent && <IconComponent class="w-6 h-6" />}
                </div>
                <div>
                  <span class="text-[9px] uppercase font-bold tracking-widest text-brand-slate-400">Category Showcase</span>
                  <h1 class="text-xl md:text-2xl font-bold text-brand-slate-900 tracking-tight">{title}</h1>
                </div>
              </div>
              <p class="text-xs md:text-sm text-brand-slate-500 leading-relaxed max-w-xl">{description}</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
              <span class="inline-flex text-[9px] font-bold text-brand-amber-800 bg-brand-amber-50 border border-brand-amber-200/60 px-2.5 py-1 rounded font-semibold">
                Original B2B Stocks Verified
              </span>
            </div>
          </div>

          <!-- Banner Image Showcase (Right Side) -->
          <div class="p-6 md:p-8 md:w-[40%] flex justify-center items-center w-full bg-brand-slate-50/50 md:bg-transparent border-t md:border-t-0 md:border-l border-brand-slate-100/80">
            <img 
              src={`${base}/images/banners/${category.id}.png`} 
              alt={`${title} products — laboratory ${title.toLowerCase()} including ${subcategories.slice(0, 3).map(s => getSubName(s).toLowerCase()).join(', ')} from brands like ${brands.slice(0, 2).join(' and ')}`}
              class="w-full max-w-[280px] md:max-w-full h-auto aspect-square object-contain rounded-lg border border-brand-slate-200/40 shadow-sm"
              loading="eager"
              width="400"
              height="400"
            />
          </div>
        </div>
      </div>

      <!-- Main Layout Split Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <!-- Main Column (70%) -->
        <div class="lg:col-span-2 space-y-10">
          
          <!-- Sub-Categories Listing -->
          <article class="bg-white border border-brand-slate-200/80 rounded-xl p-6 md:p-8 shadow-premium">
            <h2 class="text-base font-bold text-brand-slate-900 border-b border-brand-slate-100 pb-4 mb-6 tracking-tight">
              Detailed Product Ranges
            </h2>
            
            <div class="space-y-6">
              {subcategories.map((sub, idx) => (
                <div class="flex items-start gap-4 p-4 rounded-lg hover:bg-brand-slate-50 transition-colors border border-transparent hover:border-brand-slate-100/60">
                  <div class="w-6 h-6 rounded-full bg-brand-slate-100 border border-brand-slate-200 flex items-center justify-center text-[10px] font-bold text-brand-slate-600 shrink-0 mt-0.5">
                    {String(idx + 1).padStart(2, '0')}
                  </div>
                  <div class="space-y-1">
                    <h3 class="text-sm font-bold text-brand-slate-800">{getSubName(sub)}</h3>
                    <p class="text-xs text-brand-slate-500 leading-relaxed">
                      {getSubDescription(sub)}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </article>

          <!-- Brands Representation Section -->
          <article class="bg-white border border-brand-slate-200/80 rounded-xl p-6 md:p-8 shadow-premium">
            <h2 class="text-base font-bold text-brand-slate-900 border-b border-brand-slate-100 pb-4 mb-6 tracking-tight">
              Represented Premium Brands
            </h2>
            <p class="text-xs text-brand-slate-500 leading-relaxed mb-6">
              We distribute authentic products from the following leading manufacturers. Material Safety Data Sheets (MSDS) and batch calibration certificates can be provided upon request.
            </p>
            
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              {brands.map((brand) => (
                <div class="border border-brand-slate-200/60 hover:border-brand-slate-300 rounded-lg p-4 flex flex-col items-center justify-center text-center select-none bg-brand-slate-50/50 hover:bg-brand-slate-50 transition-colors shadow-sm h-20">
                  <span class="text-xs font-bold text-brand-slate-800">{brand}</span>
                  <span class="text-[9px] uppercase tracking-widest text-brand-slate-400 font-semibold mt-1">Authorized</span>
                </div>
              ))}
            </div>
          </article>

          <!-- B2B Procurement notes -->
          <div class="bg-brand-slate-900 text-white rounded-xl p-6 md:p-8 shadow-premium flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="space-y-2">
              <h3 class="text-sm md:text-base font-bold">Request Calibration & Batch Certificates</h3>
              <p class="text-[11px] md:text-xs text-brand-slate-400 max-w-lg leading-relaxed">
                Need original Pyrex batch certificates, brand conformity files, or technical datasheets? Inform our Penang sales team.
              </p>
            </div>
            <button id="open-rfq-bottom" class="inline-flex items-center justify-center px-4 py-2.5 text-xs font-bold text-white bg-brand-steel-500 hover:bg-brand-steel-600 rounded-md transition-colors shrink-0 shadow-sm">
              Request Certificate
            </button>
          </div>

        </div>

        <!-- Sidebar Column (30%) -->
        <aside class="lg:col-span-1">
          <InquirePanel categoryTitle={title} />
        </aside>

      </div>

    </div>
  </div>
</Layout>

<script>
  // Add listeners to secondary page quote triggers
  const setupPageTriggers = () => {
    const dialogElement = document.getElementById('rfq-dialog') as HTMLDialogElement;
    const bottomBtn = document.getElementById('open-rfq-bottom');

    if (dialogElement && bottomBtn) {
      bottomBtn.addEventListener('click', () => {
        dialogElement.showModal();
      });
    }
  };

  setupPageTriggers();
  document.addEventListener('astro:after-swap', setupPageTriggers);
</script>
